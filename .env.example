# Database — include connection pool settings for production
DATABASE_URL="postgresql://nomi:nomibrief2026@postgres:5432/nomibrief?schema=public&connection_limit=10&pool_timeout=5"

# Default user (used by webhook and articles API to upsert articles)
DEFAULT_USER_EMAIL="nomi@nomibrief.app"
DEFAULT_USER_NAME="Ryan"
DEFAULT_USER_AVATAR="https://avatars.githubusercontent.com/u/20233821?v=4"

# API Authentication (required for POST /api/articles and POST /api/links)
API_SECRET="your-secure-api-secret-here"

# Webhook Authentication (optional — set to secure the webhook endpoint)
WEBHOOK_SECRET="your-webhook-secret-here"

# OpenClaw Integration
OPENCLAW_URL="http://host.docker.internal:18789"
OPENCLAW_TOKEN=""

# Authentication (change these in production!)
JWT_SECRET="your-super-secret-jwt-key-change-in-production-minimum-32-chars"

# App Settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# Optional: Enable voice features
VOICE_ENABLED="true"
