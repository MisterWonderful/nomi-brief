generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatar    String?
  settings  Settings?
  articles  Article[]
  links     LinkEntry[]
  lists     List[]
  listItems ListItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme           String  @default("dark")
  openclawUrl     String?
  openclawToken   String?
  voiceEnabled    Boolean @default(true)
  notifications   Boolean @default(true)
  dailyBriefTime  String  @default("08:00")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Article {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  content     String   @db.Text
  authorName  String   @default("Nomi Vale")
  authorAvatar String?
  coverImage  String?
  category    String   @default("General")
  tags        String[]
  readTime   Int      @default(5)
  publishedAt DateTime @default(now())
  
  // Status
  isRead      Boolean @default(false)
  isFavorite  Boolean @default(false)
  isSaved     Boolean @default(false)
  savedAt     DateTime?
  isPublished Boolean @default(true)
  
  // Source tracking
  source      String?  @default("ai")
  sourceUrl   String?
  
  // Rich content (agents can push HTML content with YouTube embeds, etc.)
  contentHtml  String?   @db.Text
  
  // Relations
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  links       LinkEntry[]
  voiceSessions VoiceSession[]
  listItems   ListItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([publishedAt])
  @@index([category])
  @@index([isPublished])
  @@index([userId, isPublished])
  @@index([isRead])
}

model LinkEntry {
  id          String   @id @default(cuid())
  title       String
  url         String
  description String?
  image       String?
  source      String?  // e.g., "karakeep", "rss", "manual"
  sourceUrl   String?  // Original source link
  
  // Status
  isRead      Boolean @default(false)
  isFavorite  Boolean @default(false)
  
  // Organization
  tags        String[]
  category    String?
  
  // Relations
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  articleId   String?
  article     Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([articleId])
  @@index([isRead])
  @@index([isFavorite])
}

model VoiceSession {
  id        String   @id @default(cuid())
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  
  // Session data
  context   String?  @db.Text // Article content or link details passed to OpenClaw
  summary   String?  @db.Text // Summary of the conversation
  
  // Timing
  startedAt DateTime @default(now())
  endedAt   DateTime?
  duration  Int?     // seconds
  
  // Status
  status    String   @default("active") // active, completed, failed
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([articleId])
  @@index([status])
}

model DailyBrief {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  title       String
  summary     String?  @db.Text
  articleCount Int     @default(0)
  linkCount   Int      @default(0)
  
  createdAt   DateTime @default(now())
  
  @@index([date])
}

model List {
  id          String     @id @default(cuid())
  name        String
  description String?
  color       String     @default("violet")
  icon        String     @default("bookmark")
  sortOrder   Int        @default(0)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ListItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  @@index([userId])
}

model ListItem {
  id              String    @id @default(cuid())
  title           String
  description     String?
  url             String?
  image           String?
  notes           String?   @db.Text
  tags            String[]
  youtubeUrl      String?
  richContent     String?   @db.Text
  sourceArticleId String?
  sourceArticle   Article?  @relation(fields: [sourceArticleId], references: [id], onDelete: SetNull)
  sourceUrl       String?
  listId          String
  list            List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([listId])
  @@index([userId])
}
